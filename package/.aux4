{
  "scope": "aux4",
  "name": "voice",
  "version": "1.0.4",
  "description": "Text-to-speech CLI tool",
  "license": "Apache-2.0",
  "tags": [
    "tts",
    "say",
    "voice",
    "speech",
    "espeak"
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "voice",
          "execute": [
            "profile:voice"
          ],
          "help": {
            "text": "Text-to-speech commands"
          }
        }
      ]
    },
    {
      "name": "voice",
      "commands": [
        {
          "name": "say",
          "execute": [
            "log:Platform not supported"
          ],
          "help": {
            "text": "Speak text using text-to-speech",
            "variables": [
              {
                "name": "message",
                "text": "The text to speak",
                "default": "",
                "arg": true
              },
              {
                "name": "voice",
                "text": "The voice to use",
                "default": "Samantha"
              }
            ]
          }
        },
        {
          "name": "list",
          "execute": [
            "log:Platform not supported"
          ],
          "help": {
            "text": "List available voices",
            "variables": [
              {
                "name": "language",
                "text": "Filter by language code (e.g., en, pt, ja)",
                "default": "",
                "arg": true
              }
            ]
          }
        }
      ]
    }
  ]
}
