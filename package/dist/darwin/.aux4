{
  "platform": "darwin",
  "tags": [
    "tts",
    "say",
    "voice",
    "speech"
  ],
  "profiles": [
    {
      "name": "voice",
      "commands": [
        {
          "name": "say",
          "execute": [
            "stdin:say -v value(voice) value(message)"
          ],
          "help": {
            "text": "Speak text using text-to-speech",
            "variables": [
              {
                "name": "message",
                "text": "The text to speak",
                "default": "",
                "arg": true
              },
              {
                "name": "voice",
                "text": "The voice to use",
                "default": "Samantha"
              }
            ]
          }
        },
        {
          "name": "list",
          "execute": [
            "if(language!=) && say -v '?' | grep -i ${language} | sed -E 's/^(.*[^ ]) +([a-z]{2}_[A-Z0-9]{2,3}) +# (.*)/\\x1b[33m\\1\\x1b[0m \\x1b[36m(\\2)\\x1b[0m\\n\\x1b[90m\\3\\x1b[0m\\n/' || say -v '?' | sed -E 's/^(.*[^ ]) +([a-z]{2}_[A-Z0-9]{2,3}) +# (.*)/\\x1b[33m\\1\\x1b[0m \\x1b[36m(\\2)\\x1b[0m\\n\\x1b[90m\\3\\x1b[0m\\n/'"
          ],
          "help": {
            "text": "List available voices",
            "variables": [
              {
                "name": "language",
                "text": "Filter by language code (e.g., en, pt_BR, ja_JP)",
                "default": "",
                "arg": true
              }
            ]
          }
        }
      ]
    }
  ]
}
